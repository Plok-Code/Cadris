# Web Dockerfile — build context = repo root (monorepo workspace)
FROM node:20-alpine AS deps

WORKDIR /app

COPY package.json package-lock.json ./
COPY packages/schemas/package.json packages/schemas/
COPY packages/client-sdk/package.json packages/client-sdk/
COPY apps/web/package.json apps/web/

RUN npm ci

# ---- Build stage ----
FROM node:20-alpine AS build

WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/packages/schemas/node_modules ./packages/schemas/node_modules
COPY --from=deps /app/packages/client-sdk/node_modules ./packages/client-sdk/node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules

COPY package.json package-lock.json ./
COPY packages/schemas/ packages/schemas/
COPY packages/client-sdk/ packages/client-sdk/
COPY apps/web/ apps/web/

RUN npm run build:web

# ---- Run stage ----
FROM node:20-alpine AS run

WORKDIR /app

ENV NODE_ENV=production

COPY --from=build /app/apps/web/.next/standalone ./
COPY --from=build /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=build /app/apps/web/public ./apps/web/public

EXPOSE 3000

CMD ["node", "apps/web/server.js"]
