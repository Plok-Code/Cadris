# ─── GCP Cloud Run ────────────────────────────────────
GCP_PROJECT=cadris-prod
GCP_REGION=europe-west1

# ─── Database (Neon PostgreSQL) ───────────────────────
CONTROL_PLANE_DATABASE_URL=postgresql://user:password@host/cadris?sslmode=require

# ─── Auth ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Email (Resend — pour reset password) ─────────────
RESEND_API_KEY=re_...

# ─── Stripe billing ──────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_EXPERT=price_...

# ─── AI providers ────────────────────────────────────
CADRIS_RUNTIME_PROVIDER=collaborative
CADRIS_MODEL_PROFILE=prod
CADRIS_OPENAI_MODEL=gpt-4.1
OPENAI_API_KEY=sk-...
TOGETHER_API_KEY=
PERPLEXITY_API_KEY=pplx-...
