# Cadris Production Environment Variables
# Copy to .env.prod and fill in real values
# Usage: docker compose -f docker-compose.prod.yml --env-file deploy/.env.prod up -d

# --- Domain ---
CADRIS_DOMAIN=app.cadris.fr
FRONTEND_URL=https://app.cadris.fr
NEXTAUTH_URL=https://app.cadris.fr
NEXT_PUBLIC_CADRIS_API_URL=https://app.cadris.fr

# --- Database (Neon PostgreSQL) ---
CONTROL_PLANE_DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/cadris?sslmode=require

# --- Auth secrets ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
CONTROL_PLANE_TRUSTED_PROXY_SECRET=

# --- CORS ---
CONTROL_PLANE_ALLOWED_ORIGINS=https://app.cadris.fr

# --- OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Email (Resend — for magic link + password reset) ---
RESEND_API_KEY=

# --- OpenAI (for real agent missions) ---
OPENAI_API_KEY=
CADRIS_RUNTIME_PROVIDER=openai
CADRIS_OPENAI_MODEL=gpt-4o

# --- Stripe (billing) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_EXPERT=

# --- Storage (optional, defaults to local disk) ---
# CONTROL_PLANE_S3_BUCKET=
