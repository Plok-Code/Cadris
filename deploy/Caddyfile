# Cadris production Caddyfile
# Replace app.cadris.fr with your domain
# Caddy auto-provisions HTTPS via Let's Encrypt

{$CADRIS_DOMAIN:app.cadris.fr} {
	# Control-plane API — billing and shared links only
	# /api/auth/* is NextAuth (web), NOT control-plane
	handle /api/billing/* {
		reverse_proxy control-plane:8000
	}

	handle /api/shared/* {
		reverse_proxy control-plane:8000
	}

	# Health check (control-plane)
	handle /health {
		reverse_proxy control-plane:8000
	}

	# Everything else (including /api/auth/*, /api/cadris/*) → Next.js
	handle {
		reverse_proxy web:3000
	}

	# Security headers
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://api.stripe.com; frame-src https://js.stripe.com; font-src 'self' data:"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}

	# Gzip
	encode gzip
}
