# ─── NextAuth v5 ──────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=change-me-in-env-local

# ─── Control-plane URL (API proxy) ───────────────────
CONTROL_PLANE_URL=http://127.0.0.1:8000

# ─── OAuth providers (optionnel en dev — utiliser Dev Login) ─
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ─── Trusted proxy signature ─────────────────────────
# Même secret que dans apps/control-plane/.env — REQUIS en production
# Sans ce secret, le control-plane accepte les headers non signés (fail-open)
CONTROL_PLANE_TRUSTED_PROXY_SECRET=
