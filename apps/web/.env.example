# ─── NextAuth v5 ──────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=change-me-in-env-local

# ─── Control-plane URL (API proxy) ───────────────────
CONTROL_PLANE_URL=http://127.0.0.1:8000

# ─── Direct mode: bypass API proxy (optionnel) ───────
# NEXT_PUBLIC_CADRIS_DIRECT_MODE=true
# NEXT_PUBLIC_CADRIS_API_URL=http://127.0.0.1:8000
# NEXT_PUBLIC_CADRIS_DEV_USER_ID=dev-user

# ─── OAuth providers (optionnel en dev — utiliser Dev Login) ─
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ─── Trusted proxy signature (optionnel) ─────────────
# CONTROL_PLANE_TRUSTED_PROXY_SECRET=
