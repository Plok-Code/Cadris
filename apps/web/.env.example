# Auth.js / NextAuth v5
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=change-me-in-env-local

# Control plane URL (backend API)
CONTROL_PLANE_URL=http://127.0.0.1:8000

# Direct mode: bypass Next.js API proxy, talk to control-plane directly
# NEXT_PUBLIC_CADRIS_DIRECT_MODE=true
# NEXT_PUBLIC_CADRIS_API_URL=http://127.0.0.1:8000
# NEXT_PUBLIC_CADRIS_DEV_USER_ID=dev-user

# OAuth providers (optional for dev — use Dev Login instead)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Magic Link email (optional — needs Resend account)
# RESEND_API_KEY=

# Trusted proxy signature (optional — for HMAC-signed auth headers)
# CONTROL_PLANE_TRUSTED_PROXY_SECRET=
