# Provider: local (mock), openai (legacy 3-cycle), collaborative (multi-agent waves)
CADRIS_RUNTIME_PROVIDER=local

# Model for legacy openai engine
CADRIS_OPENAI_MODEL=gpt-4.1-nano

# Profile: dev (forces gpt-4.1-nano for all plans) | prod (plan-based model selection)
CADRIS_MODEL_PROFILE=dev

# API keys
OPENAI_API_KEY=
TOGETHER_API_KEY=

# Perplexity web research (Pro/Expert plans)
# Pro uses sonar (fast), Expert uses sonar-pro (deep research)
PERPLEXITY_API_KEY=

# State persistence (optional — defaults to local JSON files)
# CADRIS_RUNTIME_STATE_DB_URL=postgresql://...
# CADRIS_RUNTIME_STATE_DIR=data/mission-state
