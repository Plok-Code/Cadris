# ─── Provider ─────────────────────────────────────────
# local (mock) | openai (legacy) | collaborative (multi-agent waves)
CADRIS_RUNTIME_PROVIDER=local

# ─── Model config ────────────────────────────────────
# Profile: dev (gpt-4.1-nano pour tout) | prod (sélection par plan)
CADRIS_MODEL_PROFILE=dev
CADRIS_OPENAI_MODEL=gpt-4.1-nano

# ─── API keys ────────────────────────────────────────
OPENAI_API_KEY=
TOGETHER_API_KEY=

# ─── Perplexity (Pro/Expert — web research) ──────────
# Pro = sonar (fast), Expert = sonar-pro (deep research)
# PERPLEXITY_API_KEY=pplx-...

# ─── Service-to-service auth ─────────────────────────
# Vérifié sur les endpoints /internal/* (fail-closed). Même valeur que le
# control-plane. En dev sans secret, autoriser les requêtes non signées :
CADRIS_INTERNAL_SECRET=
# CADRIS_ALLOW_UNSIGNED_REQUESTS=true   # dev local uniquement

# ─── Prompts ──────────────────────────────────────────
# Dev : recharge les prompts modifiés sans redémarrer (mtime-based).
# En prod, laisser non défini (cache permanent, redéploiement requis).
# CADRIS_PROMPT_RELOAD_ENABLED=true
