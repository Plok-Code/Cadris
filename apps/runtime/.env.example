# ─── Provider ─────────────────────────────────────────
# local (mock) | openai (legacy) | collaborative (multi-agent waves)
CADRIS_RUNTIME_PROVIDER=local

# ─── Model config ────────────────────────────────────
# Profile: dev (gpt-4.1-nano pour tout) | prod (sélection par plan)
CADRIS_MODEL_PROFILE=dev
CADRIS_OPENAI_MODEL=gpt-4.1-nano

# ─── API keys ────────────────────────────────────────
OPENAI_API_KEY=
TOGETHER_API_KEY=

# ─── Perplexity (Pro/Expert — web research) ──────────
# Pro = sonar (fast), Expert = sonar-pro (deep research)
# PERPLEXITY_API_KEY=pplx-...
