# ─── Database ──────────────────────────────────────────
# SQLite par défaut en dev (pas besoin de config)
# Décommenter pour PostgreSQL local ou Neon :
# CONTROL_PLANE_DATABASE_URL=sqlite:///C:/path/to/cadris-dev.db
# CONTROL_PLANE_DATABASE_URL=postgresql://cadris:cadris_dev@localhost:5432/cadris
# CONTROL_PLANE_DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/cadris?sslmode=require

# ─── Runtime & Renderer URLs ──────────────────────────
CONTROL_PLANE_RUNTIME_URL=http://127.0.0.1:8001
CONTROL_PLANE_RENDERER_URL=http://127.0.0.1:8002

# ─── CORS ─────────────────────────────────────────────
CONTROL_PLANE_ALLOWED_ORIGINS=http://127.0.0.1:3001,http://localhost:3001

# ─── Frontend URL (pour les liens dans les emails) ────
FRONTEND_URL=http://localhost:3001

# ─── Auth (Resend — pour reset password) ──────────────
RESEND_API_KEY=re_...

# ─── Stripe billing ──────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_EXPERT=price_...

# ─── Trusted proxy signature ─────────────────────────
# Partagé avec apps/web — REQUIS en production
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
CONTROL_PLANE_TRUSTED_PROXY_SECRET=

# ─── Uploads (optionnel) ─────────────────────────────
# CONTROL_PLANE_UPLOADS_DIR=./uploads
# CONTROL_PLANE_MAX_UPLOAD_BYTES=5242880
