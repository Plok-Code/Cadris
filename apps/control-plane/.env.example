CONTROL_PLANE_RUNTIME_URL=http://127.0.0.1:8001
CONTROL_PLANE_RENDERER_URL=http://127.0.0.1:8002
CONTROL_PLANE_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
CONTROL_PLANE_UPLOADS_DIR=C:/path/to/cadris-uploads
CONTROL_PLANE_MAX_UPLOAD_BYTES=5242880

# --- Database ---
# Option 1: SQLite local (dev rapide, pas de setup)
# CONTROL_PLANE_DATABASE_URL=sqlite:///C:/path/to/cadris-dev.db

# Option 2: PostgreSQL local (docker-compose up postgres)
# CONTROL_PLANE_DATABASE_URL=postgresql://cadris:cadris_dev@localhost:5432/cadris

# Option 3: PostgreSQL Neon (production / cloud)
# CONTROL_PLANE_DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/cadris?sslmode=require

# --- Auth ---
# RESEND_API_KEY=re_...

# --- Billing ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_EXPERT=price_...
# FRONTEND_URL=http://localhost:3000
