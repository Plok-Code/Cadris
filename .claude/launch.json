{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "control-plane",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "cadris_cp.main:app", "--port", "8000"],
      "port": 8000,
      "cwd": "apps/control-plane"
    },
    {
      "name": "runtime",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "cadris_runtime.main:app", "--port", "8001"],
      "port": 8001,
      "cwd": "apps/runtime"
    },
    {
      "name": "renderer",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--port", "8002"],
      "port": 8002,
      "cwd": "apps/renderer"
    },
    {
      "name": "web",
      "runtimeExecutable": "node",
      "runtimeArgs": ["../../node_modules/next/dist/bin/next", "dev"],
      "port": 3001,
      "autoPort": true,
      "cwd": "apps/web"
    }
  ]
}
