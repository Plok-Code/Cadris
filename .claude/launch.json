{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "control-plane",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "runtime",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--port", "8001"],
      "port": 8001
    },
    {
      "name": "renderer",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--port", "8002"],
      "port": 8002
    },
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--workspace", "@cadris/web", "--", "--port", "3000"],
      "port": 3000
    }
  ]
}
