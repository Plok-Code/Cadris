{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": false,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@cadris/schemas": [
        "packages/schemas/src"
      ],
      "@cadris/client-sdk": [
        "packages/client-sdk/src"
      ]
    }
  }
}

